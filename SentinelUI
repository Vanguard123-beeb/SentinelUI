-- ================================================
-- NOTIFICATION TOAST
-- ================================================
function SentinelUI:Notify(config)
    config = config or {}
    local title    = config.Title    or "Notification"
    local message  = config.Message  or ""
    local duration = config.Duration or 3

    -- Stack existing toasts upward
    local existingToasts = {}
    for _, ch in ipairs(self.Gui:GetChildren()) do
        if ch.Name == "_SentinelToast" then
            existingToasts[#existingToasts+1] = ch
        end
    end
    local offset = #existingToasts * 70

    local notif = create("Frame", {
        Name             = "_SentinelToast",
        Size             = UDim2.new(0, 270, 0, 60),
        Position         = UDim2.new(1, 10, 1, -(20 + offset)),
        AnchorPoint      = Vector2.new(1, 1),
        BackgroundColor3 = Color3.fromRGB(22, 22, 30),
        BorderSizePixel  = 0,
        ZIndex           = 100,
        Parent           = self.Gui,
    }, { makeCorner(10), makeStroke(Theme.Accent) })

    -- Accent bar on left
    create("Frame", {
        Size             = UDim2.new(0, 3, 1, -16),
        Position         = UDim2.new(0, 0, 0, 8),
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel  = 0,
        ZIndex           = 101,
        Parent           = notif,
    }, { makeCorner(2) })

    create("TextLabel", {
        Size                   = UDim2.new(1, -28, 0, 16),
        Position               = UDim2.new(0, 16, 0, 10),
        BackgroundTransparency = 1,
        Text                   = title,
        Font                   = Enum.Font.GothamBold,
        TextSize               = 12,
        TextColor3             = Theme.TextPrimary,
        TextXAlignment         = Enum.TextXAlignment.Left,
        ZIndex                 = 101,
        Parent                 = notif,
    })

    create("TextLabel", {
        Size                   = UDim2.new(1, -28, 0, 14),
        Position               = UDim2.new(0, 16, 0, 30),
        BackgroundTransparency = 1,
        Text                   = message,
        Font                   = Enum.Font.Gotham,
        TextSize               = 10,
        TextColor3             = Theme.TextSecondary,
        TextXAlignment         = Enum.TextXAlignment.Left,
        ZIndex                 = 101,
        Parent                 = notif,
    })

    -- Slide in
    tween(notif,
        { Position = UDim2.new(1, -20, 1, -(20 + offset)) },
        0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out
    )

    -- Progress bar
    local bar = create("Frame", {
        Size             = UDim2.new(1, 0, 0, 2),
        Position         = UDim2.new(0, 0, 1, -2),
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel  = 0,
        ZIndex           = 101,
        Parent           = notif,
    })

    tween(bar, { Size = UDim2.new(0, 0, 0, 2) }, duration, Enum.EasingStyle.Linear)

    task.delay(duration, function()
        tween(notif, { Position = UDim2.new(1, 20, 1, -(20 + offset)) }, 0.2)
        task.wait(0.22)
        notif:Destroy()
    end)
end

-- ================================================
-- DESTROY
-- ================================================
function SentinelUI:Destroy()
    tween(self.Main, {
        Size     = UDim2.new(0, 0, 0, 0),
        Position = UDim2.new(0.5, 0, 0.5, 0),
    }, 0.2)
    task.delay(0.25, function()
        if self.Gui and self.Gui.Parent then
            self.Gui:Destroy()
        end
    end)
end

