-- ================================================
-- WINDOW
-- ================================================
local WINDOW_W  = 460
local WINDOW_H  = 520
local TITLE_H   = 48
local TABBAR_H  = 38

function SentinelUI.new(config)
    local self = setmetatable({}, SentinelUI)
    config = config or {}

    self.Name       = config.Name    or "SentinelUI"
    self.SubText    = config.SubText or "v1.0"
    self.Toggle     = config.Toggle  or Enum.KeyCode.RightShift
    self.Tabs       = {}
    self.ActiveTab  = nil
    self.Minimized  = false

    -- ScreenGui
    self.Gui = create("ScreenGui", {
        Name           = "SentinelUI_" .. self.Name,
        ResetOnSpawn   = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        IgnoreGuiInset = true,
    })
    local ok = pcall(function() self.Gui.Parent = CoreGui end)
    if not ok or not self.Gui.Parent then
        self.Gui.Parent = LocalPlayer:WaitForChild("PlayerGui")
    end

    -- Main frame
    self.Main = create("Frame", {
        Name             = "Main",
        Size             = UDim2.new(0, WINDOW_W, 0, WINDOW_H),
        Position         = UDim2.new(0.5, -WINDOW_W / 2, 0.5, -WINDOW_H / 2),
        BackgroundColor3 = Theme.Background,
        BorderSizePixel  = 0,
        ClipsDescendants = false,
        Parent           = self.Gui,
    }, { makeCorner(14), makeStroke(Theme.Border) })

    self:_buildTitleBar()
    self:_buildTabBar()
    self:_buildContent()
    self:_setupDrag()
    self:_setupGlobalToggle()

    return self
end

-- ================================================
-- TITLE BAR
-- ================================================
