    -- ================================================
    -- KEYBIND (rebindable + optional minimize)
    -- ================================================
    function sec:AddKeybind(config)
        config = config or {}
        local label    = config.Name     or "Keybind"
        local default  = config.Default  or Enum.KeyCode.RightShift
        local isToggle = config.IsToggle or false
        local callback = config.Callback or function() end

        local current      = default
        local binding      = false
        local linkedWindow = nil

        local row = baseRow(48)

        create("TextLabel", {
            Size                   = UDim2.new(0.55, -14, 0, 16),
            Position               = UDim2.new(0, 14, 0, 9),
            BackgroundTransparency = 1,
            Text                   = label,
            Font                   = Enum.Font.GothamBold,
            TextSize               = 12,
            TextColor3             = Theme.TextPrimary,
            TextXAlignment         = Enum.TextXAlignment.Left,
            ZIndex                 = 4,
            Parent                 = row,
        })

        create("TextLabel", {
            Size                   = UDim2.new(0, 60, 0, 13),
            Position               = UDim2.new(0, 14, 0, 27),
            BackgroundTransparency = 1,
            Text                   = isToggle and "minimize gui" or "keybind",
            Font                   = Enum.Font.Gotham,
            TextSize               = 9,
            TextColor3             = isToggle and Theme.AccentLight or Theme.TextSecondary,
            TextXAlignment         = Enum.TextXAlignment.Left,
            ZIndex                 = 4,
            Parent                 = row,
        })

        local keyPill = create("TextButton", {
            Size             = UDim2.new(0, 0, 0, 26),
            AutomaticSize    = Enum.AutomaticSize.X,
            Position         = UDim2.new(1, -14, 0.5, -13),
            AnchorPoint      = Vector2.new(1, 0),
            BackgroundColor3 = Theme.ItemBg,
            BorderSizePixel  = 0,
            Text             = tostring(current):gsub("Enum.KeyCode.", ""),
            Font             = Enum.Font.GothamBold,
            TextSize         = 11,
            TextColor3       = Theme.TextSecondary,
            ZIndex           = 5,
            Parent           = row,
        }, {
            makeCorner(6),
            makePadding(0, 0, 10, 10),
            makeStroke(Theme.Border, 1, 0),
        })

        local function applyKey(kc)
            current = kc
            keyPill.Text = tostring(kc):gsub("Enum.KeyCode.", "")
            tween(keyPill, { TextColor3 = Theme.TextSecondary }, 0.15)
            tween(keyPill, { BackgroundColor3 = Theme.ItemBg }, 0.15)
            tween(keyPill:FindFirstChildOfClass("UIStroke"), { Color = Theme.Border }, 0.15)
        end

        keyPill.MouseEnter:Connect(function()
            tween(keyPill, { BackgroundColor3 = Color3.fromRGB(34, 28, 58) }, 0.12)
        end)
        keyPill.MouseLeave:Connect(function()
            if not binding then
                tween(keyPill, { BackgroundColor3 = Theme.ItemBg }, 0.12)
            end
        end)

        keyPill.MouseButton1Click:Connect(function()
            if binding then return end
            binding = true
            keyPill.Text = "press key..."
            tween(keyPill, { TextColor3 = Theme.Accent }, 0.1)
            tween(keyPill, { BackgroundColor3 = Theme.AccentDark }, 0.1)
            tween(keyPill:FindFirstChildOfClass("UIStroke"), { Color = Theme.Accent }, 0.1)
        end)

        -- Capture rebind
        UserInputService.InputBegan:Connect(function(input, gpe)
            if not binding then return end
            if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
            if input.KeyCode == Enum.KeyCode.Escape then
                binding = false
                applyKey(current)
            else
                binding = false
                applyKey(input.KeyCode)
            end
        end)

        -- Runtime listener
        UserInputService.InputBegan:Connect(function(input, gpe)
            if gpe or binding then return end
            if input.KeyCode ~= current then return end
            if isToggle and linkedWindow then
                linkedWindow:_toggleMinimize()
            end
            pcall(callback, current)
        end)

        local ctrl = {}
        function ctrl:Get() return current end
        function ctrl:Set(kc) applyKey(kc) end
        function ctrl:SetWindow(win) linkedWindow = win end
        return ctrl
    end

