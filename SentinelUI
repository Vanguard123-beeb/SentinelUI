end

-- ================================================
-- MINIMIZE / RESTORE
-- ================================================
function SentinelUI:_toggleMinimize()
    self.Minimized = not self.Minimized

    if self.Minimized then
        self.TabBar.Visible     = false
        self.ContentFrame.Visible = false
        tween(self.Main, { Size = UDim2.new(0, WINDOW_W, 0, TITLE_H) }, 0.22, Enum.EasingStyle.Quart)
    else
        tween(self.Main, { Size = UDim2.new(0, WINDOW_W, 0, WINDOW_H) }, 0.22, Enum.EasingStyle.Quart)
        task.delay(0.1, function()
            self.TabBar.Visible      = true
            self.ContentFrame.Visible = true
        end)
    end
end

-- ================================================
-- TAB BAR
-- ================================================
function SentinelUI:_buildTabBar()
    self.TabBar = create("Frame", {
        Name             = "TabBar",
        Size             = UDim2.new(1, 0, 0, TABBAR_H),
        Position         = UDim2.new(0, 0, 0, TITLE_H),
        BackgroundColor3 = Color3.fromRGB(14, 14, 18),
        BorderSizePixel  = 0,
        ZIndex           = 2,
        Parent           = self.Main,
    }, { makeStroke(Theme.Border) })

    create("UIListLayout", {
        FillDirection = Enum.FillDirection.Horizontal,
        SortOrder     = Enum.SortOrder.LayoutOrder,
        Parent        = self.TabBar,
    })

    create("UIPadding", {
        PaddingLeft = UDim.new(0, 10),
        Parent      = self.TabBar,
    })
end

-- ================================================
-- CONTENT FRAME
-- ================================================
function SentinelUI:_buildContent()
    local contentY = TITLE_H + TABBAR_H

    self.ContentFrame = create("ScrollingFrame", {
        Name                   = "Content",
        Size                   = UDim2.new(1, 0, 1, -contentY),
        Position               = UDim2.new(0, 0, 0, contentY),
        BackgroundTransparency = 1,
        BorderSizePixel        = 0,
        ScrollBarThickness     = 3,
        ScrollBarImageColor3   = Theme.Border,
        CanvasSize             = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize    = Enum.AutomaticSize.Y,
        ZIndex                 = 2,
        Parent                 = self.Main,
    })

    create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding   = UDim.new(0, 4),
        Parent    = self.ContentFrame,
    })

    create("UIPadding", {
        PaddingTop    = UDim.new(0, 10),
        PaddingBottom = UDim.new(0, 10),
        PaddingLeft   = UDim.new(0, 12),
        PaddingRight  = UDim.new(0, 12),
        Parent        = self.ContentFrame,
    })
end

-- ================================================
-- DRAG
-- ================================================
function SentinelUI:_setupDrag()
    local dragging, dragStart, startPos

    self.TitleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging  = true
            dragStart = input.Position
            startPos  = self.Main.Position
        end
    end)

    self.TitleBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            self.Main.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
end

-- ================================================
-- GLOBAL TOGGLE KEYBIND (set in .new config)
-- ================================================
function SentinelUI:_setupGlobalToggle()
    UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.KeyCode == self.Toggle then
            self:_toggleMinimize()
        end
    end)
end

-- ================================================
-- ADD TAB
-- ================================================
function SentinelUI:AddTab(name)
    local tabData = { Name = name, Container = nil, Button = nil }

    -- Tab button
    tabData.Button = create("TextButton", {
        Size                   = UDim2.new(0, 0, 1, 0),
        AutomaticSize          = Enum.AutomaticSize.X,
        BackgroundTransparency = 1,
        Text                   = name,
        Font                   = Enum.Font.Gotham,
        TextSize               = 11,
        TextColor3             = Theme.TextSecondary,
        LayoutOrder            = #self.Tabs + 1,
        ZIndex                 = 3,
        Parent                 = self.TabBar,
    })
    makePadding(0, 0, 12, 12).Parent = tabData.Button

    tabData.Indicator = create("Frame", {
        Size                   = UDim2.new(1, 0, 0, 2),
        Position               = UDim2.new(0, 0, 1, -2),
        BackgroundColor3       = Theme.Accent,
        BackgroundTransparency = 1,
        BorderSizePixel        = 0,
        ZIndex                 = 4,
        Parent                 = tabData.Button,
    })

    -- Tab content container (inside ContentFrame)
    tabData.Container = create("Frame", {
        Size                   = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Visible                = false,
        ZIndex                 = 3,
        Parent                 = self.ContentFrame,
    })

    create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding   = UDim.new(0, 4),
        Parent    = tabData.Container,
    })

    tabData.Button.MouseButton1Click:Connect(function()
        self:_selectTab(tabData)
    end)

    table.insert(self.Tabs, tabData)

    if #self.Tabs == 1 then
        self:_selectTab(tabData)
    end

    -- Return tab builder object
    local tabObj = { _ui = self, _tab = tabData }

    function tabObj:AddSection(sectionName)
        return SentinelUI._buildSection(self._ui, self._tab, sectionName)
    end

    return tabObj
end

function SentinelUI:_selectTab(target)
    for _, t in ipairs(self.Tabs) do
        local active = t == target
        tween(t.Button, { TextColor3 = active and Theme.AccentLight or Theme.TextSecondary }, 0.15)
        tween(t.Indicator, { BackgroundTransparency = active and 0 or 1 }, 0.15)
        t.Container.Visible = active
    end
    self.ActiveTab = target
end

-- ================================================
-- SECTION BUILDER
-- ================================================
function SentinelUI._buildSection(ui, tab, sectionName)

    if sectionName and sectionName ~= "" then
        local lbl = create("TextLabel", {
            Size                   = UDim2.new(1, 0, 0, 24),
            BackgroundTransparency = 1,
            Text                   = sectionName:upper(),
            Font                   = Enum.Font.GothamBold,
            TextSize               = 9,
            TextColor3             = Theme.TextMuted,
            TextXAlignment         = Enum.TextXAlignment.Left,
            LayoutOrder            = #tab.Container:GetChildren() + 1,
            ZIndex                 = 3,
            Parent                 = tab.Container,
        })
        makePadding(4, 0, 4, 0).Parent = lbl
    end

    local sec = {}

    -- ── internal: base row ──────────────────────
    local function baseRow(h)
        local row = create("Frame", {
            Size             = UDim2.new(1, 0, 0, h or 48),
            BackgroundColor3 = Theme.Surface,
            BorderSizePixel  = 0,
            LayoutOrder      = #tab.Container:GetChildren() + 1,
            ZIndex           = 3,
            Parent           = tab.Container,
        }, { makeCorner(8), makeStroke(Theme.Border) })

        row.MouseEnter:Connect(function()
            tween(row, { BackgroundColor3 = Theme.SurfaceHover }, 0.12)
            tween(row:FindFirstChildOfClass("UIStroke"), { Color = Theme.BorderHover }, 0.12)
        end)
        row.MouseLeave:Connect(function()
            tween(row, { BackgroundColor3 = Theme.Surface }, 0.12)
            tween(row:FindFirstChildOfClass("UIStroke"), { Color = Theme.Border }, 0.12)
        end)

        return row
    end

    -- ── internal: row label + desc ───────────────
    local function rowText(parent, label, desc)
        create("TextLabel", {
            Size                   = UDim2.new(0.65, -14, 0, 16),
            Position               = UDim2.new(0, 14, 0, desc ~= "" and 9 or 0),
            AnchorPoint            = desc ~= "" and Vector2.new(0,0) or Vector2.new(0, 0.5),
            BackgroundTransparency = 1,
            Text                   = label,
            Font                   = Enum.Font.GothamBold,
            TextSize               = 12,
            TextColor3             = Theme.TextPrimary,
            TextXAlignment         = Enum.TextXAlignment.Left,
            ZIndex                 = 4,
            Parent                 = parent,
        })
        if desc ~= "" then
            create("TextLabel", {
                Size                   = UDim2.new(0.65, -14, 0, 14),
                Position               = UDim2.new(0, 14, 0, 27),
                BackgroundTransparency = 1,
                Text                   = desc,
                Font                   = Enum.Font.Gotham,
                TextSize               = 10,
                TextColor3             = Theme.TextSecondary,
                TextXAlignment         = Enum.TextXAlignment.Left,
                ZIndex                 = 4,
                Parent                 = parent,
            })
        end
    end

    -- ================================================
    -- TOGGLE
    -- ================================================
    function sec:AddToggle(config)
        config = config or {}
        local label    = config.Name     or "Toggle"
        local desc     = config.Desc     or ""
        local state    = config.Default  or false
        local callback = config.Callback or function() end

        local row = baseRow(48)
        rowText(row, label, desc)

        local track = create("Frame", {
            Size             = UDim2.new(0, 38, 0, 21),
            Position         = UDim2.new(1, -52, 0.5, -10.5),
            BackgroundColor3 = state and Theme.Accent or Theme.KnobOff,
            BorderSizePixel  = 0,
            ZIndex           = 4,
            Parent           = row,
        }, {
            makeCorner(11),
            makeStroke(state and Theme.AccentLight or Theme.KnobOffBorder),
        })

        local knob = create("Frame", {
            Size             = UDim2.new(0, 15, 0, 15),
            Position         = state and UDim2.new(0, 20, 0.5, -7.5) or UDim2.new(0, 3, 0.5, -7.5),
            BackgroundColor3 = state and Theme.White or Theme.TextSecondary,
            BorderSizePixel  = 0,
            ZIndex           = 5,
            Parent           = track,
        }, { makeCorner(8) })

        local function refresh()
            tween(track, { BackgroundColor3 = state and Theme.Accent or Theme.KnobOff }, 0.2)
            tween(track:FindFirstChildOfClass("UIStroke"), {
                Color = state and Theme.AccentLight or Theme.KnobOffBorder
            }, 0.2)
            tween(knob, {
                Position         = state and UDim2.new(0, 20, 0.5, -7.5) or UDim2.new(0, 3, 0.5, -7.5),
                BackgroundColor3 = state and Theme.White or Theme.TextSecondary,
            }, 0.2)
        end

        create("TextButton", {
            Size                   = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Text                   = "",
            ZIndex                 = 6,
            Parent                 = row,
        }).MouseButton1Click:Connect(function()
            state = not state
            refresh()
            pcall(callback, state)
        end)

        local ctrl = {}
        function ctrl:Set(v) state = v refresh() pcall(callback, state) end
        function ctrl:Get() return state end
        return ctrl
    end

    -- ================================================
    -- BUTTON
    -- ================================================
    function sec:AddButton(config)
        config = config or {}
        local label    = config.Name     or "Button"
        local desc     = config.Desc     or ""
        local style    = config.Style    or "default"
        local callback = config.Callback or function() end

        local bgColor, textColor, borderColor

        if style == "accent" then
            bgColor, textColor, borderColor =
                Theme.Accent, Theme.White, Theme.AccentLight
        elseif style == "danger" then
            bgColor, textColor, borderColor =
                Theme.DangerBg, Theme.Danger, Theme.DangerBorder
        else
            bgColor, textColor, borderColor =
                Theme.Surface, Theme.TextPrimary, Theme.Border
        end

        local row = create("Frame", {
            Size             = UDim2.new(1, 0, 0, desc ~= "" and 48 or 40),
            BackgroundColor3 = bgColor,
            BorderSizePixel  = 0,
            LayoutOrder      = #tab.Container:GetChildren() + 1,
            ZIndex           = 3,
            Parent           = tab.Container,
        }, { makeCorner(8), makeStroke(borderColor) })

        rowText(row, label, desc)

        -- Arrow indicator on right
        create("TextLabel", {
            Size                   = UDim2.new(0, 16, 1, 0),
            Position               = UDim2.new(1, -28, 0, 0),
            BackgroundTransparency = 1,
            Text                   = "›",
            Font                   = Enum.Font.GothamBold,
            TextSize               = 16,
            TextColor3             = style == "accent" and Color3.fromRGB(200, 190, 255) or Theme.TextMuted,
            ZIndex                 = 4,
            Parent                 = row,
        })

        local btn = create("TextButton", {
            Size                   = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Text                   = "",
            ZIndex                 = 5,
            Parent                 = row,
        })

        btn.MouseEnter:Connect(function()
            tween(row, {
                BackgroundColor3 = style == "accent" and Theme.AccentHover or Theme.SurfaceHover
            }, 0.12)
            tween(row:FindFirstChildOfClass("UIStroke"), { Color = Theme.BorderHover }, 0.12)
        end)
        btn.MouseLeave:Connect(function()
            tween(row, { BackgroundColor3 = bgColor }, 0.12)
            tween(row:FindFirstChildOfClass("UIStroke"), { Color = borderColor }, 0.12)
        end)
        btn.MouseButton1Click:Connect(function()
            tween(row, { BackgroundColor3 = style == "accent" and Color3.fromRGB(100, 78, 210) or Theme.Border }, 0.05)
            task.delay(0.1, function()
                tween(row, { BackgroundColor3 = bgColor }, 0.15)
            end)
            pcall(callback)
        end)
    end

    -- ================================================
    -- SLIDER
    -- ================================================
    function sec:AddSlider(config)
        config = config or {}
        local label    = config.Name     or "Slider"
        local min      = config.Min      or 0
        local max      = config.Max      or 100
        local default  = config.Default  or 50
        local suffix   = config.Suffix   or ""
        local callback = config.Callback or function() end

        local value    = math.clamp(default, min, max)
        local dragging = false

        local row = create("Frame", {
            Size             = UDim2.new(1, 0, 0, 54),
            BackgroundColor3 = Theme.Surface,
            BorderSizePixel  = 0,
            LayoutOrder      = #tab.Container:GetChildren() + 1,
            ZIndex           = 3,
            Parent           = tab.Container,
        }, { makeCorner(8), makeStroke(Theme.Border) })

        row.MouseEnter:Connect(function()
            tween(row, { BackgroundColor3 = Theme.SurfaceHover }, 0.12)
            tween(row:FindFirstChildOfClass("UIStroke"), { Color = Theme.BorderHover }, 0.12)
        end)
        row.MouseLeave:Connect(function()
            tween(row, { BackgroundColor3 = Theme.Surface }, 0.12)
            tween(row:FindFirstChildOfClass("UIStroke"), { Color = Theme.Border }, 0.12)
        end)

        create("TextLabel", {
            Size                   = UDim2.new(0.6, -14, 0, 16),
            Position               = UDim2.new(0, 14, 0, 10),
            BackgroundTransparency = 1,
            Text                   = label,
            Font                   = Enum.Font.GothamBold,
            TextSize               = 12,
            TextColor3             = Theme.TextPrimary,
            TextXAlignment         = Enum.TextXAlignment.Left,
            ZIndex                 = 4,
            Parent                 = row,
        })

        local valLbl = create("TextLabel", {
            Size                   = UDim2.new(0, 64, 0, 16),
            Position               = UDim2.new(1, -78, 0, 10),
            BackgroundTransparency = 1,
            Text                   = tostring(value) .. suffix,
            Font                   = Enum.Font.GothamBold,
            TextSize               = 11,
            TextColor3             = Theme.Accent,
            TextXAlignment         = Enum.TextXAlignment.Right,
            ZIndex                 = 4,
            Parent                 = row,
        })

        local trackBg = create("Frame", {
            Size             = UDim2.new(1, -28, 0, 4),
            Position         = UDim2.new(0, 14, 0, 36),
            BackgroundColor3 = Theme.KnobOff,
            BorderSizePixel  = 0,
            ZIndex           = 4,
            Parent           = row,
        }, { makeCorner(2) })

        local fill = create("Frame", {
            Size             = UDim2.new((value - min) / (max - min), 0, 1, 0),
            BackgroundColor3 = Theme.Accent,
            BorderSizePixel  = 0,
            ZIndex           = 5,
            Parent           = trackBg,
        }, { makeCorner(2) })

        local knob = create("Frame", {
            Size             = UDim2.new(0, 14, 0, 14),
            AnchorPoint      = Vector2.new(0.5, 0.5),
            Position         = UDim2.new((value - min) / (max - min), 0, 0.5, 0),
            BackgroundColor3 = Theme.White,
            BorderSizePixel  = 0,
            ZIndex           = 6,
            Parent           = trackBg,
        }, { makeCorner(7) })

        local function updateSlider(pct)
            pct   = math.clamp(pct, 0, 1)
            value = math.floor(min + (max - min) * pct + 0.5)
            value = math.clamp(value, min, max)
            fill.Size     = UDim2.new(pct, 0, 1, 0)
            knob.Position = UDim2.new(pct, 0, 0.5, 0)
            valLbl.Text   = tostring(value) .. suffix
            pcall(callback, value)
        end

        local grabBtn = create("TextButton", {
            Size                   = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Text                   = "",
            ZIndex                 = 7,
            Parent                 = trackBg,
        })

        grabBtn.MouseButton1Down:Connect(function()
            dragging = true
            local trackX = trackBg.AbsolutePosition.X
            local trackW = trackBg.AbsoluteSize.X
            updateSlider((UserInputService:GetMouseLocation().X - trackX) / trackW)
        end)

        UserInputService.InputChanged:Connect(function(input)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                local trackX = trackBg.AbsolutePosition.X
                local trackW = trackBg.AbsoluteSize.X
                updateSlider((input.Position.X - trackX) / trackW)
            end
        end)

        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)

        local ctrl = {}
        function ctrl:Set(v)
            local pct = (math.clamp(v, min, max) - min) / (max - min)
            updateSlider(pct)
        end
        function ctrl:Get() return value end
        return ctrl
    end

    -- ================================================
    -- DROPDOWN (single + multi + search)
    -- ================================================
    function sec:AddDropdown(config)
        config = config or {}
        local label    = config.Name     or "Dropdown"
        local options  = config.Options  or {}
        local multi    = config.Multi    or false
        local callback = config.Callback or function() end

        -- Normalise selection state
        local selected
        if multi then
            selected = {}
            for _, v in ipairs(type(config.Default) == "table" and config.Default or {}) do
                selected[v] = true
            end
        else
            selected = config.Default or (options[1] or "")
        end

        local open        = false
        local searchQuery = ""

        -- Row shell
        local row = create("Frame", {
            Size             = UDim2.new(1, 0, 0, 48),
            BackgroundColor3 = Theme.Surface,
            BorderSizePixel  = 0,
            ClipsDescendants = false,
            LayoutOrder      = #tab.Container:GetChildren() + 1,
            ZIndex           = 5,
            Parent           = tab.Container,
        }, { makeCorner(8), makeStroke(Theme.Border) })

        row.MouseEnter:Connect(function()
            tween(row:FindFirstChildOfClass("UIStroke"), { Color = Theme.BorderHover }, 0.12)
        end)
        row.MouseLeave:Connect(function()
            tween(row:FindFirstChildOfClass("UIStroke"), { Color = Theme.Border }, 0.12)
        end)

        create("TextLabel", {
            Size                   = UDim2.new(0.45, 0, 0, 16),
            Position               = UDim2.new(0, 14, 0, 9),
            BackgroundTransparency = 1,
            Text                   = label,
            Font                   = Enum.Font.GothamBold,
            TextSize               = 12,
            TextColor3             = Theme.TextPrimary,
            TextXAlignment         = Enum.TextXAlignment.Left,
            ZIndex                 = 6,
            Parent                 = row,
        })

        -- Mode badge
        create("TextLabel", {
            Size                   = UDim2.new(0, 44, 0, 13),
            Position               = UDim2.new(0, 14, 0, 27),
            BackgroundTransparency = 1,
            Text                   = multi and "multi-select" or "single",
            Font                   = Enum.Font.Gotham,
            TextSize               = 9,
            TextColor3             = multi and Theme.AccentLight or Theme.TextSecondary,
            TextXAlignment         = Enum.TextXAlignment.Left,
            ZIndex                 = 6,
            Parent                 = row,
        })

        local valLbl = create("TextLabel", {
            Size                   = UDim2.new(0.45, -36, 0, 16),
            Position               = UDim2.new(0.45, 0, 0, 9),
            BackgroundTransparency = 1,
            Text                   = "",
            Font                   = Enum.Font.Gotham,
            TextSize               = 10,
            TextColor3             = Theme.AccentLight,
            TextXAlignment         = Enum.TextXAlignment.Right,
            TextTruncate           = Enum.TextTruncate.AtEnd,
            ZIndex                 = 6,
            Parent                 = row,
        })

        local arrow = create("TextLabel", {
            Size                   = UDim2.new(0, 18, 0, 16),
            Position               = UDim2.new(1, -28, 0, 9),
            BackgroundTransparency = 1,
            Text                   = "▼",
            Font                   = Enum.Font.Gotham,
            TextSize               = 9,
            TextColor3             = Theme.TextSecondary,
            ZIndex                 = 6,
            Parent                 = row,
        })

        -- Dropdown panel
        local panel = create("Frame", {
            Size             = UDim2.new(1, 0, 0, 0),
            Position         = UDim2.new(0, 0, 1, 4),
            BackgroundColor3 = Theme.PanelBg,
            BorderSizePixel  = 0,
            ClipsDescendants = true,
            ZIndex           = 20,
            Parent           = row,
        }, { makeCorner(8), makeStroke(Theme.Border) })

        -- Search bar
        local searchBox = create("TextBox", {
            Size              = UDim2.new(1, -16, 0, 28),
            Position          = UDim2.new(0, 8, 0, 6),
            BackgroundColor3  = Theme.SurfaceDeep,
            BorderSizePixel   = 0,
            Text              = "",
            PlaceholderText   = "Search...",
            Font              = Enum.Font.Gotham,
            TextSize          = 11,
            TextColor3        = Theme.TextPrimary,
            PlaceholderColor3 = Theme.TextMuted,
            TextXAlignment    = Enum.TextXAlignment.Left,
            ClearTextOnFocus  = false,
            ZIndex            = 22,
            Parent            = panel,
        }, { makeCorner(6), makePadding(0, 0, 8, 8) })

        create("TextLabel", {
            Size                   = UDim2.new(0, 20, 0, 28),
            Position               = UDim2.new(1, -28, 0, 6),
            BackgroundTransparency = 1,
            Text                   = "⌕",
            Font                   = Enum.Font.GothamBold,
            TextSize               = 14,
            TextColor3             = Theme.TextMuted,
            ZIndex                 = 23,
            Parent                 = panel,
        })

        -- Scrollable list
        local listFrame = create("ScrollingFrame", {
            Size                   = UDim2.new(1, 0, 1, -42),
            Position               = UDim2.new(0, 0, 0, 42),
            BackgroundTransparency = 1,
            BorderSizePixel        = 0,
            ScrollBarThickness     = 3,
            ScrollBarImageColor3   = Theme.Border,
            CanvasSize             = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize    = Enum.AutomaticSize.Y,
            ZIndex                 = 21,
            Parent                 = panel,
        })

        create("UIListLayout", {
            SortOrder = Enum.SortOrder.LayoutOrder,
            Parent    = listFrame,
        })

        local function updatePreview()
            if multi then
                local picks = {}
                for _, opt in ipairs(options) do
                    if selected[opt] then picks[#picks+1] = opt end
                end
                valLbl.Text = #picks == 0 and "none" or table.concat(picks, ", ")
            else
                valLbl.Text = tostring(selected)
            end
        end

        local function buildItems()
            for _, ch in ipairs(listFrame:GetChildren()) do
                if not ch:IsA("UIListLayout") then ch:Destroy() end
            end

            local count = 0
            for i, opt in ipairs(options) do
                if searchQuery ~= "" and not opt:lower():find(searchQuery:lower(), 1, true) then
                    continue
                end

                count = count + 1
                local isSel = multi and selected[opt] or (not multi and selected == opt)

                local item = create("TextButton", {
                    Size             = UDim2.new(1, 0, 0, 34),
                    BackgroundColor3 = isSel and Theme.ItemSelected or Theme.PanelBg,
                    BorderSizePixel  = 0,
                    Text             = "",
                    LayoutOrder      = i,
                    ZIndex           = 22,
                    Parent           = listFrame,
                })

                create("TextLabel", {
                    Size                   = UDim2.new(0, 18, 1, 0),
                    Position               = UDim2.new(0, 10, 0, 0),
                    BackgroundTransparency = 1,
                    Text                   = isSel and (multi and "☑" or "●") or (multi and "☐" or ""),
                    Font                   = Enum.Font.GothamBold,
                    TextSize               = 12,
                    TextColor3             = Theme.Accent,
                    ZIndex                 = 23,
                    Parent                 = item,
                })

                create("TextLabel", {
                    Size                   = UDim2.new(1, -34, 1, 0),
                    Position               = UDim2.new(0, 30, 0, 0),
                    BackgroundTransparency = 1,
                    Text                   = opt,
                    Font                   = Enum.Font.Gotham,
                    TextSize               = 11,
                    TextColor3             = isSel and Theme.AccentLight or Theme.TextSecondary,
                    TextXAlignment         = Enum.TextXAlignment.Left,
                    ZIndex                 = 23,
                    Parent                 = item,
                })

                item.MouseEnter:Connect(function()
                    tween(item, { BackgroundColor3 = Color3.fromRGB(34, 28, 58) }, 0.1)
                end)
                item.MouseLeave:Connect(function()
                    local sel2 = multi and selected[opt] or (not multi and selected == opt)
                    tween(item, { BackgroundColor3 = sel2 and Theme.ItemSelected or Theme.PanelBg }, 0.1)
                end)

                item.MouseButton1Click:Connect(function()
                    if multi then
                        if selected[opt] then selected[opt] = nil else selected[opt] = true end
                        pcall(callback, selected)
                        updatePreview()
                        buildItems()
                    else
                        selected = opt
                        open = false
                        tween(panel, { Size = UDim2.new(1, 0, 0, 0) }, 0.18)
                        tween(arrow, { Rotation = 0 }, 0.18)
                        pcall(callback, selected)
                        updatePreview()
                        buildItems()
                    end
                end)
            end

            if count == 0 then
                create("TextLabel", {
                    Size                   = UDim2.new(1, 0, 0, 34),
                    BackgroundTransparency = 1,
                    Text                   = "No results for \"" .. searchQuery .. "\"",
                    Font                   = Enum.Font.Gotham,
                    TextSize               = 11,
                    TextColor3             = Theme.TextMuted,
                    ZIndex                 = 22,
                    Parent                 = listFrame,
                })
            end

            return count
        end

        searchBox:GetPropertyChangedSignal("Text"):Connect(function()
            searchQuery = searchBox.Text
            buildItems()
        end)

        local triggerBtn = create("TextButton", {
            Size                   = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Text                   = "",
            ZIndex                 = 7,
            Parent                 = row,
        })

        triggerBtn.MouseButton1Click:Connect(function()
            open = not open
            searchQuery  = ""
            searchBox.Text = ""
            local visCount = buildItems()
            local panelH   = math.min(visCount * 34 + 42 + 8, 220)
            tween(panel, { Size = UDim2.new(1, 0, 0, open and panelH or 0) }, 0.2)
            tween(arrow, { Rotation = open and 180 or 0 }, 0.2)
            if open then
                task.delay(0.22, function() searchBox:CaptureFocus() end)
            end
        end)

        updatePreview()
        buildItems()

        local ctrl = {}

        function ctrl:Get()
            if multi then
                local out = {}
                for _, opt in ipairs(options) do
                    if selected[opt] then out[#out+1] = opt end
                end
                return out
            end
            return selected
        end

        function ctrl:Set(val)
            if multi then
                selected = {}
                if type(val) == "table" then
                    for _, v in ipairs(val) do selected[v] = true end
                end
            else
                selected = val
            end
            updatePreview()
            buildItems()
        end

        function ctrl:SetOptions(opts)
            options = opts
            if multi then
                local valid = {}
                for _, v in ipairs(opts) do valid[v] = true end
                for k in pairs(selected) do
                    if not valid[k] then selected[k] = nil end
                end
            else
                local still = false
                for _, v in ipairs(opts) do
                    if v == selected then still = true break end
                end
                if not still then selected = opts[1] or "" end
            end
            updatePreview()
            buildItems()
        end

        function ctrl:IsOpen() return open end

        return ctrl
    end

