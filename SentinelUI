    SurfaceHover  = Color3.fromRGB(26, 26, 34),
    SurfaceDeep   = Color3.fromRGB(14, 14, 20),
    Border        = Color3.fromRGB(42, 42, 53),
    BorderHover   = Color3.fromRGB(58, 58, 85),
    Accent        = Color3.fromRGB(124, 94, 247),
