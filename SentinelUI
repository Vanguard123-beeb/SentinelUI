        TextXAlignment         = Enum.TextXAlignment.Left,
        ZIndex                 = 3,
        Parent                 = self.TitleBar,
    })

    -- Minimize button
    local minBtn = create("TextButton", {
        Size             = UDim2.new(0, 22, 0, 22),
        Position         = UDim2.new(1, -62, 0.5, -11),
        BackgroundColor3 = Theme.KnobOff,
        BorderSizePixel  = 0,
        Text             = "–",
        Font             = Enum.Font.GothamBold,
        TextSize         = 13,
        TextColor3       = Theme.TextSecondary,
        ZIndex           = 3,
        Parent           = self.TitleBar,
    }, { makeCorner(11) })

    minBtn.MouseEnter:Connect(function()
        tween(minBtn, { BackgroundColor3 = Theme.Accent }, 0.15)
        tween(minBtn, { TextColor3 = Theme.White }, 0.15)
    end)
    minBtn.MouseLeave:Connect(function()
        tween(minBtn, { BackgroundColor3 = Theme.KnobOff }, 0.15)
        tween(minBtn, { TextColor3 = Theme.TextSecondary }, 0.15)
    end)
    minBtn.MouseButton1Click:Connect(function()
        self:_toggleMinimize()
    end)

    -- Close button
    local closeBtn = create("TextButton", {
        Size             = UDim2.new(0, 22, 0, 22),
        Position         = UDim2.new(1, -34, 0.5, -11),
        BackgroundColor3 = Theme.KnobOff,
        BorderSizePixel  = 0,
        Text             = "✕",
        Font             = Enum.Font.Gotham,
        TextSize         = 11,
        TextColor3       = Theme.TextSecondary,
        ZIndex           = 3,
        Parent           = self.TitleBar,
    }, { makeCorner(11) })

    closeBtn.MouseEnter:Connect(function()
        tween(closeBtn, { BackgroundColor3 = Theme.Danger }, 0.15)
        tween(closeBtn, { TextColor3 = Theme.White }, 0.15)
    end)
    closeBtn.MouseLeave:Connect(function()
        tween(closeBtn, { BackgroundColor3 = Theme.KnobOff }, 0.15)
